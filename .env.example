# ──────────────────────────────────────────
# GestureOS AI — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# Camera
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# Model paths
MODEL_DIR=models/weights
DEFAULT_MODEL=gesture_classifier_v1.onnx

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# UI
UI_THEME=dark
UI_OVERLAY_OPACITY=0.85

# Debug
DEBUG=False
